[Unit]
Description=Phone Camera (scrcpy)
After=network.target

[Service]
Type=simple
ExecStart=scrcpy \
  --video-source=camera \
  --camera-facing=back \
  --camera-size=1920x1080 \
  --camera-fps=30 \
  --video-bit-rate=50M \
  --v4l2-sink=/dev/video10 \
  --no-audio --no-window \
  --video-codec=h265 \
  --video-encoder=OMX.qcom.video.encoder.hevc \
	--audio-source=mic \
	--audio-codec=aac
Restart=no
RestartSec=3

[Install]
WantedBy=default.target
